.tenant-shell {
  min-height: 100vh;
  display: flex;
  background:
    radial-gradient(circle at 12% 8%, rgba(37, 99, 235, 0.12), transparent 36%),
    radial-gradient(circle at 88% 10%, rgba(14, 165, 233, 0.12), transparent 32%),
    linear-gradient(180deg, #f7faff 0%, #eef3ff 48%, #f7f9fd 100%);
}

.tenant-sidebar {
  width: 260px;
  background: rgba(255, 255, 255, 0.78);
  border-right: 1px solid rgba(148, 163, 184, 0.2);
  backdrop-filter: blur(14px);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20px 18px;
  position: sticky;
  top: 0;
  height: 100vh;
}

.tenant-logo-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}

.tenant-logo-mark {
  width: 32px;
  height: 32px;
  border-radius: 12px;
  background: linear-gradient(135deg, #1d4ed8, #0284c7);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  box-shadow: 0 10px 24px rgba(37, 99, 235, 0.45);
}

.tenant-logo-text {
  display: flex;
  flex-direction: column;
}

.tenant-logo-title {
  font-size: 15px;
  font-weight: 600;
}

.tenant-logo-sub {
  font-size: 11px;
  color: var(--text-muted);
}

.tenant-nav {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.nav-item {
  border: none;
  border-radius: 12px;
  padding: 9px 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.18s ease;
}

.nav-item:hover {
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
  transform: translateX(2px);
}

.nav-item .nav-icon {
  width: 24px;
  text-align: center;
}

.nav-item.active {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.16), rgba(2, 132, 199, 0.08));
  color: #1d4ed8;
  font-weight: 600;
  box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.2);
}

.tenant-sidebar-bottom {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.tenant-mini-card {
  padding: 10px 12px;
  border-radius: 14px;
  background: linear-gradient(140deg, #0f172a 0%, #1e293b 100%);
  box-shadow: 0 14px 30px rgba(15, 23, 42, 0.25);
}

.tenant-tenant-name {
  font-size: 13px;
  font-weight: 600;
  color: #f8fafc;
}

.tenant-tenant-unit {
  font-size: 11px;
  color: #cbd5e1;
}

.tenant-help-btn {
  border-radius: 999px;
  border: none;
  background: #0f172a;
  color: #e5e7eb;
  padding: 8px 14px;
  font-size: 13px;
  cursor: pointer;
  transition: background 0.2s;
}

.tenant-help-btn:hover {
  background: #1e293b;
}

.tenant-logout-btn {
  border-radius: 999px;
  border: 1px solid #ef4444;
  background: transparent;
  color: #ef4444;
  padding: 8px 14px;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 8px;
}

.tenant-logout-btn:hover {
  background: #ef4444;
  color: white;
}

.tenant-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 20px 28px;
  gap: 20px;
}

.tenant-header {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: center;
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(148, 163, 184, 0.24);
  border-radius: 18px;
  padding: 16px 18px;
  backdrop-filter: blur(10px);
}

.tenant-page-title {
  font-size: 22px;
  letter-spacing: -0.04em;
  margin: 0;
}

.tenant-page-sub {
  margin-top: 4px;
  font-size: 14px;
  color: var(--text-secondary);
}

.tenant-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.tenant-icon-btn {
  border-radius: 999px;
  border: none;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.16s ease;
}

.tenant-icon-btn:hover {
  transform: translateY(-1px);
}

.tenant-avatar-chip {
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.26);
  padding: 3px 8px 3px 3px;
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(255, 255, 255, 0.92);
}

.tenant-avatar-circle {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  background: #0f172a;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e5e7eb;
  font-size: 13px;
  font-weight: 600;
}

.tenant-avatar-meta {
  display: flex;
  flex-direction: column;
}

.tenant-avatar-name {
  font-size: 13px;
  font-weight: 600;
}

.tenant-avatar-sub {
  font-size: 11px;
  color: var(--text-muted);
}

.tenant-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.tenant-grid {
  display: grid;
  gap: 16px;
}

.top-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.middle-grid {
  grid-template-columns: minmax(0, 2fr) minmax(0, 1.3fr);
  align-items: flex-start;
}

.tenant-card {
  background: rgba(255, 255, 255, 0.88);
  border: 1px solid rgba(148, 163, 184, 0.2);
  border-radius: 18px;
  padding: 16px 18px;
  box-shadow: 0 14px 35px rgba(37, 99, 235, 0.08);
  backdrop-filter: blur(8px);
}

.tenant-card:hover {
  box-shadow: 0 18px 42px rgba(37, 99, 235, 0.12);
}

.status-card .status-label-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-muted);
}

.status-value {
  font-size: 22px;
  font-weight: 700;
  margin-top: 6px;
}

.status-sub {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 2px;
}

.status-pill {
  padding: 2px 8px;
  border-radius: 999px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.status-pill.positive {
  background: #dcfce7;
  color: #15803d;
}

.status-pill.warning {
  background: #fef3c7;
  color: #b45309;
}

.status-pill.danger {
  background: #fee2e2;
  color: #b91c1c;
}

.residence-card .residence-main {
  display: grid;
  grid-template-columns: minmax(0, 1.7fr) minmax(0, 1.5fr);
  gap: 14px;
  margin-top: 10px;
}

.residence-image {
  border-radius: 14px;
  background-image:
    linear-gradient(135deg, rgba(219, 234, 254, 0.92), rgba(245, 243, 255, 0.82)),
    radial-gradient(circle at 22% 24%, rgba(14, 165, 233, 0.3), transparent 42%),
    radial-gradient(circle at 78% 76%, rgba(37, 99, 235, 0.3), transparent 40%);
  height: 140px;
  border: 1px solid rgba(148, 163, 184, 0.2);
}

.residence-meta .residence-unit-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--text-muted);
}

.residence-unit {
  font-weight: 600;
  margin-top: 2px;
}

.residence-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
  margin-top: 12px;
}

.residence-foot-label {
  font-size: 11px;
  color: var(--text-muted);
}

.residence-foot-value {
  font-size: 13px;
  font-weight: 500;
}

.section-title {
  font-size: 15px;
  font-weight: 600;
}

.quick-actions-card .qa-primary,
.qa-primary {
  border-radius: 14px;
  border: none;
  background: linear-gradient(135deg, #1d4ed8, #0284c7);
  color: #fff;
  padding: 10px 14px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2px;
  font-size: 14px;
  cursor: pointer;
  transition: transform 0.16s ease, box-shadow 0.16s ease;
  box-shadow: 0 10px 24px rgba(29, 78, 216, 0.35);
}

.quick-actions-card .qa-primary:hover,
.qa-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 26px rgba(29, 78, 216, 0.42);
}

.qa-primary.wide {
  width: 100%;
  align-items: center;
}

.qa-sub {
  font-size: 11px;
  color: #bfdbfe;
}

.qa-secondary {
  border-radius: 12px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.95);
  padding: 9px 12px;
  font-size: 13px;
  text-align: left;
  cursor: pointer;
  transition: all 0.16s ease;
}

.qa-secondary:hover {
  border-color: rgba(37, 99, 235, 0.35);
  background: #f8fbff;
}

.qa-help {
  margin-top: 14px;
  padding: 12px;
  border-radius: 16px;
  background: linear-gradient(145deg, #0f172a, #1e293b);
  color: #e5e7eb;
}

.qa-help-title {
  font-size: 14px;
  font-weight: 600;
}

.qa-help-sub {
  font-size: 12px;
  margin-top: 4px;
}

.qa-help-btn {
  margin-top: 10px;
  border-radius: 999px;
  border: none;
  padding: 7px 14px;
  background: #f9fafb;
  color: #111827;
  font-size: 12px;
}

.announcements-card .ann-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ann-list {
  margin-top: 12px;
  display: grid;
  gap: 10px;
}

.ann-item {
  padding: 10px 0;
  border-top: 1px solid var(--border-light);
}

.ann-item:first-child {
  border-top: none;
}

.ann-tag {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #2563eb;
}

.ann-item h3 {
  margin: 4px 0;
  font-size: 14px;
}

.ann-item p {
  font-size: 13px;
  color: var(--text-secondary);
}

.ann-meta {
  font-size: 11px;
  color: var(--text-muted);
}

.ann-link,
.link-btn {
  border: none;
  background: none;
  color: #2563eb;
  font-size: 12px;
  cursor: pointer;
}

.bills-grid {
  grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.7fr);
}

.bills-summary-label {
  font-size: 12px;
  color: var(--text-muted);
}

.bills-summary-amount {
  font-size: 26px;
  font-weight: 700;
  margin-top: 4px;
}

.bills-summary-sub {
  font-size: 12px;
  color: #b91c1c;
  margin-top: 2px;
}

.charges {
  margin-top: 16px;
  padding-top: 10px;
  border-top: 1px solid var(--border-light);
}

.charges-header {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
}

.charges-period {
  font-size: 11px;
  color: var(--text-muted);
}

.charges-list {
  list-style: none;
  padding: 0;
  margin: 8px 0 0;
  display: grid;
  gap: 4px;
  font-size: 13px;
}

.charges-list li {
  display: flex;
  justify-content: space-between;
}

.charges-footer {
  margin-top: 8px;
  display: flex;
  justify-content: space-between;
  font-weight: 600;
  font-size: 13px;
}

.charges-total {
  color: #2563eb;
}

.accepted-methods {
  margin-top: 16px;
  padding-top: 10px;
  border-top: 1px dashed var(--border-light);
}

.accepted-label {
  font-size: 12px;
  color: var(--text-muted);
}

.accepted-icons {
  margin-top: 6px;
  display: flex;
  gap: 8px;
}

.bills-history-card .bills-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 10px;
  font-size: 12px;
}

.bills-table th,
.bills-table td {
  padding: 8px 6px;
  text-align: left;
}

.bills-table thead {
  background: rgba(37, 99, 235, 0.08);
}

.bills-support-card {
  margin-top: 14px;
  padding: 12px;
  border-radius: 14px;
  background: linear-gradient(145deg, #0f172a, #1e293b);
  color: #e5e7eb;
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
}

.bills-support-actions {
  display: flex;
  gap: 8px;
}

.tenant-maint .maint-form-card select,
.tenant-maint .maint-form-card textarea {
  border-radius: 10px;
  border: 1px solid var(--border);
  padding: 8px 10px;
  font-size: 13px;
}

.maint-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin-top: 10px;
}

.upload-area {
  margin-top: 10px;
  border-radius: 14px;
  border: 1px dashed var(--border);
  background: linear-gradient(180deg, #f8fbff, #eff6ff);
  padding: 18px;
  text-align: center;
  font-size: 13px;
}

.upload-icon {
  font-size: 18px;
}

.maint-grid {
  grid-template-columns: minmax(0, 1.6fr) minmax(0, 1.4fr);
}

.maint-list {
  list-style: none;
  padding: 0;
  margin: 10px 0;
  display: grid;
  gap: 8px;
}

.maint-item {
  padding: 8px 0;
  border-bottom: 1px solid var(--border-light);
}

.maint-code {
  font-size: 11px;
  color: var(--text-muted);
}

.maint-main {
  font-size: 13px;
  font-weight: 500;
}

.maint-sub {
  font-size: 11px;
  color: var(--text-muted);
}

.status-pill.small {
  font-size: 10px;
}

.status-pill.neutral {
  background: #e5e7eb;
  color: #374151;
}

.maint-tracking {
  margin-top: 16px;
}

.tracking-steps {
  list-style: none;
  padding: 0;
  margin: 10px 0 0;
  display: grid;
  gap: 10px;
}

.tracking-step {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.step-dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  margin-top: 4px;
  background: #d1d5db;
}

.tracking-step.active .step-dot {
  background: #2563eb;
}

.step-dot.pending {
  background: #e5e7eb;
}

.step-title {
  font-size: 13px;
  font-weight: 500;
}

.step-sub {
  font-size: 11px;
  color: var(--text-muted);
}

.profile-card {
  padding: 18px 20px;
}

.profile-section {
  margin-bottom: 16px;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 14px;
}

.profile-avatar-lg {
  width: 60px;
  height: 60px;
  border-radius: 999px;
  background: linear-gradient(145deg, #0f172a, #334155);
  color: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 600;
}

.profile-name {
  font-size: 18px;
}

.profile-id {
  font-size: 12px;
  color: var(--text-muted);
}

.profile-badges {
  margin-top: 6px;
  display: flex;
  gap: 6px;
}

.badge-positive {
  padding: 2px 8px;
  border-radius: 999px;
  background: #dcfce7;
  color: #15803d;
  font-size: 11px;
}

.badge-outline {
  padding: 2px 8px;
  border-radius: 999px;
  border: 1px solid #e5e7eb;
  font-size: 11px;
}

.profile-contract-btn {
  margin-left: auto;
}

.profile-section-title {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 8px;
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.profile-field-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.contract-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.profile-field {
  font-size: 13px;
}

.profile-label {
  font-size: 11px;
  color: var(--text-muted);
}

.profile-value {
  font-weight: 500;
}

.terms-block {
  margin-top: 10px;
  background: linear-gradient(180deg, #f8fbff, #f4f7ff);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 14px;
  padding: 10px 12px;
}

.terms-title {
  font-size: 13px;
  font-weight: 600;
}

.terms-list {
  margin: 6px 0 0;
  padding-left: 18px;
  font-size: 12px;
  color: var(--text-secondary);
}

.digital-contract {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px solid var(--border-light);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
}

.digital-label {
  font-size: 12px;
  font-weight: 500;
}

.digital-hash {
  font-size: 11px;
  color: var(--text-muted);
}

.digital-actions {
  display: flex;
  gap: 8px;
}

@media (max-width: 1024px) {
  .tenant-sidebar {
    display: none;
  }

  .tenant-main {
    padding-inline: 16px;
  }

  .tenant-header {
    padding: 14px;
  }

  .top-grid,
  .middle-grid,
  .bills-grid,
  .maint-grid,
  .grid-two,
  .profile-field-grid {
    grid-template-columns: minmax(0, 1fr);
  }
}

/* ════════════════════════════════════════
   NEW COMPONENTS STYLES
════════════════════════════════════════ */

/* Spinner */
.tp-spinner-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 160px;
}

.tp-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid rgba(37, 99, 235, 0.2);
  border-top-color: #1d4ed8;
  border-radius: 50%;
  animation: tp-spin 0.7s linear infinite;
}

@keyframes tp-spin {
  to { transform: rotate(360deg); }
}

/* Language toggle button */
.tp-lang-btn {
  border-radius: 999px;
  border: 1px solid rgba(148, 163, 184, 0.38);
  background: rgba(255, 255, 255, 0.9);
  color: var(--text-secondary);
  padding: 7px 14px;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.18s ease;
}

.tp-lang-btn:hover {
  background: #eff6ff;
  border-color: #93c5fd;
  color: #1d4ed8;
}

/* Error / success banners */
.tp-error {
  background: #fee2e2;
  color: #b91c1c;
  border: 1px solid #fca5a5;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 13px;
  margin-bottom: 12px;
}

.tp-success {
  background: #dcfce7;
  color: #15803d;
  border: 1px solid #86efac;
  border-radius: 12px;
  padding: 10px 14px;
  font-size: 13px;
  margin-bottom: 12px;
}

.tp-warn {
  background: #fef9c3;
  color: #854d0e;
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 13px;
  margin-bottom: 10px;
}

.tp-empty {
  color: var(--text-muted);
  font-size: 13px;
  padding: 10px 0;
}

.tp-all-paid {
  margin-top: 12px;
  text-align: center;
  font-size: 14px;
  color: #15803d;
  background: #f0fdf4;
  padding: 10px;
  border-radius: 12px;
}

/* No contract card */
.tp-no-contract {
  text-align: center;
  padding: 32px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}

.tp-no-contract-icon {
  font-size: 48px;
}

.tp-no-contract h3 {
  margin: 0;
  font-size: 17px;
}

.tp-no-contract p {
  margin: 0;
  font-size: 14px;
  color: var(--text-secondary);
  max-width: 360px;
}

/* Avatar upload */
.tp-avatar-upload-wrap {
  position: relative;
  display: inline-block;
}

.tp-avatar-lg {
  width: 72px;
  height: 72px;
  font-size: 28px;
  font-weight: 700;
}

.tp-avatar-edit-btn {
  position: absolute;
  bottom: 0;
  right: -4px;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  border: 2px solid #fff;
  background: #1d4ed8;
  color: #fff;
  font-size: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 0.16s;
}

.tp-avatar-edit-btn:hover {
  background: #1e40af;
}

.tp-avatar-img {
  display: block;
}

/* Contract modal */
.tp-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
}

.tp-modal-box {
  background: #fff;
  border-radius: 18px;
  width: 100%;
  max-width: 720px;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.25);
  overflow: hidden;
}

.tp-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 18px;
  border-bottom: 1px solid #e5e7eb;
  font-weight: 600;
  font-size: 15px;
}

.tp-modal-header button {
  border: none;
  background: none;
  font-size: 18px;
  cursor: pointer;
  color: var(--text-muted);
}

.tp-modal-body {
  overflow-y: auto;
  padding: 18px;
  font-size: 13px;
  line-height: 1.7;
}

/* Rooms grid */
.tp-rooms-page {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.tp-rooms-info-card {
  padding: 12px 16px;
}

.tp-rooms-info-card p {
  margin: 0;
  font-size: 13px;
  color: var(--text-secondary);
}

.tp-rooms-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
}

.tp-room-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.tp-room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tp-room-number {
  font-size: 16px;
  font-weight: 700;
}

.tp-room-type {
  font-size: 11px;
  background: #dbeafe;
  color: #1d4ed8;
  border-radius: 999px;
  padding: 2px 8px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.tp-room-details {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6px;
  font-size: 13px;
}

.tp-room-details > div {
  display: flex;
  flex-direction: column;
}

.tp-room-details > div span {
  font-size: 11px;
  color: var(--text-muted);
}

.tp-room-price {
  color: #1d4ed8;
  font-size: 14px;
}

.tp-room-desc {
  font-size: 12px;
  color: var(--text-secondary);
  margin: 0;
}

.qa-secondary.wide {
  width: 100%;
  text-align: center;
}

/* maint form inputs */
.maint-form-card input[type="text"],
.maint-form-card select,
.maint-form-card textarea {
  width: 100%;
  border-radius: 10px;
  border: 1px solid var(--border, #e5e7eb);
  padding: 8px 10px;
  font-size: 13px;
  font-family: inherit;
  outline: none;
  transition: border-color 0.16s;
  box-sizing: border-box;
}

.maint-form-card input[type="text"]:focus,
.maint-form-card select:focus,
.maint-form-card textarea:focus {
  border-color: #1d4ed8;
}

.login-field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 10px;
}

.login-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--text-secondary, #64748b);
}

/* bills table */
.bills-history-header {
  margin-bottom: 8px;
}

/* tenant-avatar-chip as button */
.tenant-avatar-chip {
  cursor: pointer;
}

.tenant-avatar-chip:hover {
  background: #f8fbff;
}

